FROM        node:22-slim
ARG         NPM_ACCESS_TOKEN

# Install dependencies
RUN apt-get update && \
    npm i -g npm && \
    apt-get install -y --no-install-recommends \
    gnupg \
    software-properties-common \
    curl \
    lsb-release \
    wget \
    unzip \
    nginx \
    git \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    procps \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Terraform
RUN curl -fsSL https://releases.hashicorp.com/terraform/1.3.5/terraform_1.3.5_linux_amd64.zip -o /tmp/terraform.zip && \
    unzip -o /tmp/terraform.zip -d /usr/local/bin && \
    rm /tmp/terraform.zip && \
    chmod +x /usr/local/bin/terraform

# Create python3.12 symlink for compatibility (Debian bookworm has Python 3.11 by default)
RUN python3 --version && \
    ln -sf $(which python3) /usr/bin/python3.12 2>/dev/null || true && \
    ln -sf $(which python3) /usr/local/bin/python3.12 2>/dev/null || true

# Create bashrc with SSH agent configuration
RUN         printf '%s\n' \
            'SSH_ENV="$HOME/.ssh/agent-environment"' \
            '' \
            'function start_agent {' \
            '    echo "Initialising new SSH agent..."' \
            '    /usr/bin/ssh-agent | sed "s/^echo/#echo/" > "${SSH_ENV}"' \
            '    echo succeeded' \
            '    chmod 600 "${SSH_ENV}"' \
            '    . "${SSH_ENV}" > /dev/null' \
            '    /usr/bin/ssh-add;' \
            '}' \
            '' \
            '# Source SSH settings, if applicable' \
            'if [ -f "${SSH_ENV}" ]; then' \
            '    . "${SSH_ENV}" > /dev/null' \
            '    ps -ef | grep ${SSH_AGENT_PID} | grep ssh-agent$ > /dev/null || {' \
            '        start_agent;' \
            '    }' \
            'else' \
            '    start_agent;' \
            'fi' > /root/.bashrc

# Configure SSH (use prepare-build.sh or build.sh to set up SSH keys)
# Create .ssh directory
RUN         mkdir -p /root/.ssh
# Copy SSH keys (directory structure exists, may be empty)
COPY        ops/docker/.temp/.ssh /root/.ssh/
RUN         if [ -n "$(ls -A /root/.ssh 2>/dev/null | grep -v '\.gitkeep')" ]; then \
                chmod 400 /root/.ssh/* 2>/dev/null || true; \
                rm -f /root/.ssh/.gitkeep 2>/dev/null || true; \
            fi

# Install Global NPM Libs
ENV         NPM_ACCESS_TOKEN=${NPM_ACCESS_TOKEN}
RUN         npm i -g lerna npm-check-updates

# Install Python dependencies globally for development
RUN         python3 -m pip install --no-cache-dir --break-system-packages --upgrade pip && \
            python3 -m pip install --no-cache-dir --break-system-packages \
            fastapi \
            uvicorn[standard] \
            pydantic \
            boto3 \
            botocore \
            requests \
            beautifulsoup4 \
            feedparser

RUN         echo 'export PATH=~/.local/bin:$PATH' >> ~/.bashrc && \
            echo 'export PYTHONPATH=/world-brief/app:$PYTHONPATH' >> ~/.bashrc

RUN         mkdir -p /world-brief/app
WORKDIR     /world-brief/app

# Set Python path
ENV         PYTHONPATH=/world-brief/app

CMD         ["sleep", "infinity"]